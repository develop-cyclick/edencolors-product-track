# =================================
# EdenColors Production Environment
# =================================

# Database
DB_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://edencolors:CHANGE_ME_strong_password_here@postgres:5432/edencolors?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME
QR_TOKEN_SECRET=CHANGE_ME

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# Cloudflare R2
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=edencolors-assets
R2_PUBLIC_URL=https://pub-xxx.r2.dev
