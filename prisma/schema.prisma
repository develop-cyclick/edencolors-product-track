// Prisma Schema for QR Authenticity & Activation System
// Stack: Next.js + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  MANAGER
  WAREHOUSE
}

enum ProductStatus {
  PENDING_LINK  // QR ที่สร้างล่วงหน้า รอเชื่อมโยง
  IN_STOCK      // อยู่ในคลัง
  PENDING_OUT   // รอส่งออก (รออนุมัติ)
  SHIPPED       // ส่งออกแล้ว
  ACTIVATED     // ลูกค้าเปิดใช้แล้ว
  RETURNED      // คืนสินค้า
  DAMAGED       // เสียหาย รอซ่อม
  BORROWED      // ยืมสินค้า
  SCRAPPED      // ทิ้ง/ทำลายแล้ว
}

enum BorrowStatus {
  PENDING       // รออนุมัติ
  APPROVED      // อนุมัติแล้ว
  REJECTED      // ปฏิเสธ
  RETURNED      // คืนแล้ว
}

enum QRTokenStatus {
  ACTIVE
  REVOKED
}

enum OutboundStatus {
  DRAFT
  PENDING       // รออนุมัติ
  APPROVED      // อนุมัติแล้ว
  REJECTED      // ปฏิเสธ
}

enum InspectionStatus {
  OK            // ถูกต้องครบถ้วน
  DAMAGED       // เสียหาย
  CLAIM         // เคลม
  BROKEN        // แตก
  INCOMPLETE    // ไม่ครบ
}

enum ActivationType {
  SINGLE        // Activate ได้ครั้งเดียว
  PACK          // Activate ได้หลายครั้ง (กำหนดจำนวน)
}

enum GRNReceivingStatus {
  PARTIAL       // รับบางส่วน
  COMPLETE      // รับครบแล้ว
}

enum DamagedActionType {
  RESTORE       // คืนเข้าคลัง
  SCRAP         // ทิ้งสินค้า
}

enum DamagedActionStatus {
  PENDING       // รออนุมัติ
  APPROVED      // อนุมัติแล้ว
  REJECTED      // ปฏิเสธ
}

// ============================================
// MASTER DATA TABLES (Dropdowns)
// ============================================

model ProductMaster {
  id              Int            @id @default(autoincrement())
  sku             String         @unique
  serialCode      String         @unique @db.Char(5) @map("serial_code")
  nameTh          String         @map("name_th")
  nameEn          String?        @map("name_en")
  imageUrl        String?        @map("image_url")
  categoryId      Int            @map("category_id")
  modelSize       String?        @map("model_size")
  description     String?        @db.Text
  defaultUnitId   Int?           @map("default_unit_id")
  activationType  ActivationType @default(SINGLE) @map("activation_type")
  maxActivations  Int            @default(1) @map("max_activations")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  category            ProductCategory     @relation(fields: [categoryId], references: [id])
  defaultUnit         Unit?               @relation(fields: [defaultUnitId], references: [id])
  productItems        ProductItem[]
  purchaseOrderLines  PurchaseOrderLine[]
  preGeneratedBatches PreGeneratedBatch[]
  grnPlanLines        GRNPlanLine[]

  @@index([sku])
  @@index([isActive])
  @@map("product_masters")
}

model ProductCategory {
  id        Int      @id @default(autoincrement())
  nameTh    String   @map("name_th")
  nameEn    String?  @map("name_en")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products       ProductItem[]
  productMasters ProductMaster[]

  @@map("product_categories")
}

model Unit {
  id        Int      @id @default(autoincrement())
  nameTh    String   @map("name_th")
  nameEn    String?  @map("name_en")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  grnLines              GRNLine[]
  outboundLines         OutboundLine[]
  productMastersDefault ProductMaster[]
  borrowLines           BorrowTransactionLine[]
  grnPlanLines          GRNPlanLine[]

  @@map("units")
}

model ShippingMethod {
  id        Int      @id @default(autoincrement())
  nameTh    String   @map("name_th")
  nameEn    String?  @map("name_en")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outbounds OutboundHeader[]

  @@map("shipping_methods")
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  grnHeaders      GRNHeader[]
  outboundHeaders OutboundHeader[]

  @@map("warehouses")
}

// ============================================
// USER & CLINIC
// ============================================

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  passwordHash   String   @map("password_hash")
  displayName    String   @map("display_name")
  role           UserRole
  isActive       Boolean  @default(true) @map("is_active")
  forcePwChange  Boolean  @default(false) @map("force_pw_change")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  grnHeadersCreated       GRNHeader[]           @relation("GRNCreatedBy")
  grnHeadersApproved      GRNHeader[]           @relation("GRNApprovedBy")
  grnHeadersRejected      GRNHeader[]           @relation("GRNRejectedBy")
  outboundsCreated        OutboundHeader[]      @relation("OutboundCreatedBy")
  outboundsApproved       OutboundHeader[]      @relation("OutboundApprovedBy")
  purchaseOrdersCreated   PurchaseOrder[]       @relation("POCreatedBy")
  preGeneratedBatches     PreGeneratedBatch[]   @relation("PreGenBatchCreatedBy")
  eventLogs               EventLog[]
  borrowsCreated          BorrowTransaction[]   @relation("BorrowCreatedBy")
  borrowsApproved         BorrowTransaction[]   @relation("BorrowApprovedBy")
  borrowsRejected         BorrowTransaction[]   @relation("BorrowRejectedBy")
  grnReceivingSessions    GRNReceivingSession[] @relation("GRNSessionReceivedBy")
  damagedActionsCreated   DamagedActionRequest[] @relation("DamagedActionCreatedBy")
  damagedActionsApproved  DamagedActionRequest[] @relation("DamagedActionApprovedBy")

  @@map("users")
}

model Clinic {
  id           Int      @id @default(autoincrement())
  name         String
  province     String
  branchName   String?  @map("branch_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products        ProductItem[]
  outbounds       OutboundHeader[]
  purchaseOrders  PurchaseOrder[]

  @@map("clinics")
}

// ============================================
// PRODUCT & QR TOKEN
// ============================================

model ProductItem {
  id                    Int           @id @default(autoincrement())
  serial12              String        @unique @db.VarChar(20)
  productMasterId       Int?          @map("product_master_id")
  sku                   String
  name                  String
  categoryId            Int           @map("category_id")
  modelSize             String?       @map("model_size") // รุ่น/ขนาด/ปริมาณบรรจุ
  lot                   String?
  mfgDate               DateTime?     @map("mfg_date") @db.Date
  expDate               DateTime?     @map("exp_date") @db.Date
  status                ProductStatus @default(IN_STOCK)
  activationCount       Int           @default(0) @map("activation_count") // จำนวนครั้งที่ Activate แล้ว
  assignedClinicId      Int?          @map("assigned_clinic_id")
  preGeneratedBatchId   Int?          @map("pre_generated_batch_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  productMaster       ProductMaster?      @relation(fields: [productMasterId], references: [id])
  category            ProductCategory     @relation(fields: [categoryId], references: [id])
  assignedClinic      Clinic?             @relation(fields: [assignedClinicId], references: [id])
  preGeneratedBatch   PreGeneratedBatch?  @relation(fields: [preGeneratedBatchId], references: [id])
  qrTokens            QRToken[]
  activations         Activation[]        // รองรับ activation หลายครั้ง (สำหรับ PACK)
  grnLine             GRNLine?
  outboundLines       OutboundLine[]
  scanLogs            ScanLog[]
  eventLogs           EventLog[]
  borrowLines         BorrowTransactionLine[]
  damagedActionRequests DamagedActionRequest[]

  @@index([serial12])
  @@index([status])
  @@index([productMasterId])
  @@index([preGeneratedBatchId])
  @@map("product_items")
}

model QRToken {
  id            Int           @id @default(autoincrement())
  productItemId Int           @map("product_item_id")
  tokenVersion  Int           @default(1) @map("token_version")
  token         String?       @db.Text // เก็บ encrypted token จริง (optional for migration)
  tokenHash     String        @map("token_hash") // Hash ของ encrypted token
  status        QRTokenStatus @default(ACTIVE)
  issuedAt      DateTime      @default(now()) @map("issued_at")
  revokedAt     DateTime?     @map("revoked_at")
  revokeReason  String?       @map("revoke_reason")

  productItem ProductItem @relation(fields: [productItemId], references: [id])
  scanLogs    ScanLog[]

  @@unique([productItemId, tokenVersion])
  @@index([tokenHash])
  @@map("qr_tokens")
}

// ============================================
// GRN (Goods Received Note) - รับเข้าคลัง
// ============================================

model GRNHeader {
  id                Int       @id @default(autoincrement())
  grnNo             String    @unique @map("grn_no") // Auto: GRN-2026-000001
  receivedAt        DateTime  @map("received_at")
  receivedById      Int       @map("received_by_id") // พนักงานตรวจรับ
  warehouseId       Int       @map("warehouse_id")
  poNo              String?   @map("po_no")
  supplierName      String    @map("supplier_name")
  deliveryNoteNo    String?   @map("delivery_note_no")
  supplierAddress   String?   @map("supplier_address")
  supplierPhone     String?   @map("supplier_phone")
  supplierContact   String?   @map("supplier_contact") // ชื่อผู้รับ
  deliveryDocDate   DateTime? @map("delivery_doc_date")
  approvedById      Int?      @map("approved_by_id")
  approvedAt        DateTime? @map("approved_at")
  rejectedById      Int?      @map("rejected_by_id")
  rejectedAt        DateTime? @map("rejected_at")
  rejectReason      String?   @map("reject_reason")
  remarks             String?
  receivingStatus     GRNReceivingStatus @default(COMPLETE) @map("receiving_status")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  receivedBy          User       @relation("GRNCreatedBy", fields: [receivedById], references: [id])
  approvedBy          User?      @relation("GRNApprovedBy", fields: [approvedById], references: [id])
  rejectedBy          User?      @relation("GRNRejectedBy", fields: [rejectedById], references: [id])
  warehouse           Warehouse  @relation(fields: [warehouseId], references: [id])
  lines               GRNLine[]
  planLines           GRNPlanLine[]
  receivingSessions   GRNReceivingSession[]

  @@map("grn_headers")
}

model GRNLine {
  id                Int              @id @default(autoincrement())
  grnHeaderId       Int              @map("grn_header_id")
  productItemId     Int              @unique @map("product_item_id") // 1 line = 1 serial
  sku               String
  itemName          String           @map("item_name")
  modelSize         String?          @map("model_size")
  quantity          Int              @default(1)
  unitId            Int              @map("unit_id")
  lot               String?
  mfgDate           DateTime?        @map("mfg_date") @db.Date
  expDate           DateTime?        @map("exp_date") @db.Date
  inspectionStatus  InspectionStatus @default(OK) @map("inspection_status")
  remarks              String?
  receivingSessionId   Int?             @map("receiving_session_id")
  createdAt            DateTime         @default(now()) @map("created_at")

  grnHeader         GRNHeader            @relation(fields: [grnHeaderId], references: [id])
  productItem       ProductItem          @relation(fields: [productItemId], references: [id])
  unit              Unit                 @relation(fields: [unitId], references: [id])
  receivingSession  GRNReceivingSession? @relation(fields: [receivingSessionId], references: [id])

  @@map("grn_lines")
}

model GRNPlanLine {
  id               Int              @id @default(autoincrement())
  grnHeaderId      Int              @map("grn_header_id")
  productMasterId  Int              @map("product_master_id")
  totalQty         Int              @map("total_qty")
  receivedQty      Int              @default(0) @map("received_qty")
  unitId           Int              @map("unit_id")
  lot              String?
  mfgDate          DateTime?        @map("mfg_date") @db.Date
  expDate          DateTime?        @map("exp_date") @db.Date
  inspectionStatus InspectionStatus @default(OK) @map("inspection_status")
  remarks          String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  grnHeader     GRNHeader     @relation(fields: [grnHeaderId], references: [id])
  productMaster ProductMaster @relation(fields: [productMasterId], references: [id])
  unit          Unit          @relation(fields: [unitId], references: [id])

  @@map("grn_plan_lines")
}

model GRNReceivingSession {
  id           Int      @id @default(autoincrement())
  grnHeaderId  Int      @map("grn_header_id")
  sessionNo    Int      @map("session_no")
  receivedById Int      @map("received_by_id")
  receivedAt   DateTime @map("received_at")
  itemCount    Int      @map("item_count")
  remarks      String?
  createdAt    DateTime @default(now()) @map("created_at")

  grnHeader  GRNHeader @relation(fields: [grnHeaderId], references: [id])
  receivedBy User      @relation("GRNSessionReceivedBy", fields: [receivedById], references: [id])
  lines      GRNLine[]

  @@unique([grnHeaderId, sessionNo])
  @@map("grn_receiving_sessions")
}

// ============================================
// OUTBOUND (Delivery Note) - ส่งออก
// ============================================

model OutboundHeader {
  id                Int            @id @default(autoincrement())
  deliveryNoteNo    String         @unique @map("delivery_note_no") // Auto: OUT-2026-000001
  contractNo        String?        @map("contract_no")
  shippedAt         DateTime?      @map("shipped_at")
  createdById       Int            @map("created_by_id")
  warehouseId       Int            @map("warehouse_id")
  shippingMethodId  Int            @map("shipping_method_id")
  salesPersonName   String?        @map("sales_person_name")
  companyContact    String?        @map("company_contact") // ชื่อบริษัท/Line ID/เบอร์โทร/email
  clinicId          Int            @map("clinic_id")
  clinicAddress     String?        @map("clinic_address")
  clinicPhone       String?        @map("clinic_phone")
  clinicEmail       String?        @map("clinic_email")
  clinicContactName String?        @map("clinic_contact_name")
  purchaseOrderId   Int?           @map("purchase_order_id")
  status            OutboundStatus @default(DRAFT)
  approvedById      Int?           @map("approved_by_id")
  approvedAt        DateTime?      @map("approved_at")
  rejectReason      String?        @map("reject_reason")
  remarks           String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  createdBy      User            @relation("OutboundCreatedBy", fields: [createdById], references: [id])
  approvedBy     User?           @relation("OutboundApprovedBy", fields: [approvedById], references: [id])
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  shippingMethod ShippingMethod  @relation(fields: [shippingMethodId], references: [id])
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  purchaseOrder  PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  lines          OutboundLine[]

  @@index([purchaseOrderId])
  @@map("outbound_headers")
}

model OutboundLine {
  id            Int      @id @default(autoincrement())
  outboundId    Int      @map("outbound_id")
  productItemId Int      @map("product_item_id")
  sku           String
  itemName      String   @map("item_name")
  modelSize     String?  @map("model_size")
  quantity      Int      @default(1)
  unitId        Int      @map("unit_id")
  lot           String?
  expDate       DateTime? @map("exp_date") @db.Date
  itemStatus    String?  @map("item_status") // สภาพปกติ/มีข้อสังเกต
  createdAt     DateTime @default(now()) @map("created_at")

  outbound    OutboundHeader @relation(fields: [outboundId], references: [id])
  productItem ProductItem    @relation(fields: [productItemId], references: [id])
  unit        Unit           @relation(fields: [unitId], references: [id])

  @@map("outbound_lines")
}

// ============================================
// ACTIVATION - ลูกค้าเปิดใช้งาน
// ============================================

model Activation {
  id               Int      @id @default(autoincrement())
  productItemId    Int      @map("product_item_id")
  activationNumber Int      @default(1) @map("activation_number") // ครั้งที่ activate (1, 2, 3...)
  customerName     String?  @map("customer_name") // optional
  age              Int?     // optional
  gender           String?  // M/F/Other - optional
  province         String?  // optional
  phone            String?
  consentAt        DateTime @map("consent_at")
  policyVersion    String   @map("policy_version")
  createdAt        DateTime @default(now()) @map("created_at")

  productItem ProductItem @relation(fields: [productItemId], references: [id])

  @@unique([productItemId, activationNumber]) // หนึ่ง productItem หนึ่ง activationNumber
  @@map("activations")
}

// ============================================
// LOGS
// ============================================

model ScanLog {
  id            Int      @id @default(autoincrement())
  productItemId Int      @map("product_item_id")
  qrTokenId     Int?     @map("qr_token_id")
  tokenVersion  Int      @map("token_version")
  result        String   // GENUINE_IN_STOCK, GENUINE_SHIPPED, ACTIVATED, RETURNED, REPRINTED, INVALID_TOKEN, NOT_FOUND, REVOKED
  ipHash        String?  @map("ip_hash")
  userAgent     String?  @map("user_agent")
  scannedAt     DateTime @default(now()) @map("scanned_at")

  productItem ProductItem @relation(fields: [productItemId], references: [id])
  qrToken     QRToken?    @relation(fields: [qrTokenId], references: [id])

  @@index([scannedAt])
  @@map("scan_logs")
}

model EventLog {
  id            Int      @id @default(autoincrement())
  eventType     String   @map("event_type") // INBOUND, OUTBOUND, APPROVE, REJECT, REPRINT, RETURN, ACTIVATE
  productItemId Int?     @map("product_item_id")
  userId        Int?     @map("user_id")
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  productItem ProductItem? @relation(fields: [productItemId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([createdAt])
  @@map("event_logs")
}

// ============================================
// SEQUENCE COUNTERS (for auto-running numbers)
// ============================================

model SequenceCounter {
  id          Int    @id @default(autoincrement())
  name        String @unique // SERIAL, GRN, OUTBOUND, PO, PRE_GEN
  prefix      String // e.g., "GRN-2026-"
  currentVal  BigInt @default(0) @map("current_val")

  @@map("sequence_counters")
}

// ============================================
// PRE-GENERATED QR BATCH
// ============================================

model PreGeneratedBatch {
  id              Int           @id @default(autoincrement())
  batchNo         String        @unique @map("batch_no") // PG-2026-000001
  quantity        Int
  linkedCount     Int           @default(0) @map("linked_count")
  productMasterId Int           @map("product_master_id")
  createdById     Int           @map("created_by_id")
  remarks         String?
  createdAt       DateTime      @default(now()) @map("created_at")

  productMaster ProductMaster   @relation(fields: [productMasterId], references: [id])
  createdBy     User            @relation("PreGenBatchCreatedBy", fields: [createdById], references: [id])
  productItems  ProductItem[]

  @@index([batchNo])
  @@map("pre_generated_batches")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique // e.g., "verify.showClinicInfo"
  value     String   // JSON string for flexibility
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================
// PURCHASE ORDER - ใบสั่งซื้อ
// ============================================

enum POStatus {
  DRAFT         // ร่าง
  CONFIRMED     // ยืนยันแล้ว
  PARTIAL       // ส่งบางส่วนแล้ว
  COMPLETED     // ส่งครบแล้ว
  CANCELLED     // ยกเลิก
}

model PurchaseOrder {
  id                Int       @id @default(autoincrement())
  poNo              String    @unique @map("po_no") // Auto: PO-2026-000001
  clinicId          Int       @map("clinic_id")
  status            POStatus  @default(DRAFT)
  remarks           String?
  // Delivery info (ย้ายมาจาก outbound)
  deliveryNoteNo    String?   @map("delivery_note_no") // IV No.
  contractNo        String?   @map("contract_no")
  salesPersonName   String?   @map("sales_person_name")
  companyContact    String?   @map("company_contact")
  clinicAddress     String?   @map("clinic_address")
  clinicPhone       String?   @map("clinic_phone")
  clinicEmail       String?   @map("clinic_email")
  clinicContactName String?   @map("clinic_contact_name")
  createdById       Int       @map("created_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  createdBy       User      @relation("POCreatedBy", fields: [createdById], references: [id])
  lines           PurchaseOrderLine[]
  outbounds       OutboundHeader[]

  @@index([clinicId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id               Int      @id @default(autoincrement())
  purchaseOrderId  Int      @map("purchase_order_id")
  productMasterId  Int      @map("product_master_id")
  quantity         Int      // จำนวนที่สั่งฝาก
  shippedQuantity  Int      @default(0) @map("shipped_quantity") // จำนวนที่ส่งแล้ว
  createdAt        DateTime @default(now()) @map("created_at")

  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productMaster    ProductMaster @relation(fields: [productMasterId], references: [id])

  @@map("purchase_order_lines")
}

// ============================================
// BORROW TRANSACTION - ยืม/คืนสินค้า
// ============================================

model BorrowTransaction {
  id                Int           @id @default(autoincrement())
  transactionNo     String        @unique @map("transaction_no") // Auto: BR-YYYY-NNNNNN
  type              String        // 'BORROW' | 'RETURN'
  status            BorrowStatus  @default(PENDING)
  borrowerName      String        @map("borrower_name")
  clinicName        String?       @map("clinic_name")
  clinicAddress     String?       @map("clinic_address")
  taxInvoiceRef     String?       @map("tax_invoice_ref")
  reason            String?
  remarks           String?
  createdById       Int           @map("created_by_id")
  approvedById      Int?          @map("approved_by_id")
  approvedAt        DateTime?     @map("approved_at")
  rejectedById      Int?          @map("rejected_by_id")
  rejectedAt        DateTime?     @map("rejected_at")
  rejectedReason    String?       @map("rejected_reason")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  createdBy         User          @relation("BorrowCreatedBy", fields: [createdById], references: [id])
  approvedBy        User?         @relation("BorrowApprovedBy", fields: [approvedById], references: [id])
  rejectedBy        User?         @relation("BorrowRejectedBy", fields: [rejectedById], references: [id])
  lines             BorrowTransactionLine[]

  @@index([status])
  @@index([type])
  @@map("borrow_transactions")
}

model BorrowTransactionLine {
  id                    Int               @id @default(autoincrement())
  borrowTransactionId   Int               @map("borrow_transaction_id")
  productItemId         Int               @map("product_item_id")
  sku                   String
  itemName              String            @map("item_name")
  modelSize             String?           @map("model_size")
  quantity              Int               @default(1)
  unitId                Int               @map("unit_id")
  lot                   String?
  expDate               DateTime?         @map("exp_date") @db.Date
  remarks               String?
  createdAt             DateTime          @default(now()) @map("created_at")

  borrowTransaction     BorrowTransaction @relation(fields: [borrowTransactionId], references: [id], onDelete: Cascade)
  productItem           ProductItem       @relation(fields: [productItemId], references: [id])
  unit                  Unit              @relation(fields: [unitId], references: [id])

  @@map("borrow_transaction_lines")
}

// ============================================
// DAMAGED ACTION REQUEST - คำขออนุมัติทิ้ง/คืนคลัง
// ============================================

model DamagedActionRequest {
  id              Int                  @id @default(autoincrement())
  productItemId   Int                  @map("product_item_id")
  actionType      DamagedActionType    @map("action_type")
  status          DamagedActionStatus  @default(PENDING)
  repairNote      String?              @map("repair_note")
  createdById     Int                  @map("created_by_id")
  approvedById    Int?                 @map("approved_by_id")
  approvedAt      DateTime?            @map("approved_at")
  rejectReason    String?              @map("reject_reason")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  productItem     ProductItem          @relation(fields: [productItemId], references: [id])
  createdBy       User                 @relation("DamagedActionCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?                @relation("DamagedActionApprovedBy", fields: [approvedById], references: [id])

  @@index([status])
  @@index([productItemId])
  @@map("damaged_action_requests")
}
